# Telegram News Bot Configuration

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHANNEL_ID=YOUR_CHANNEL_ID_HERE  # e.g., @your_channel_name

# Ollama (Local AI) - установите Ollama и модель
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# AI Fallback - если Ollama недоступен
USE_OLLAMA=true

# Планировщик (часы публикации по МСК)
PUBLISH_HOURS=9,12,15,18,21

# RSS новостные ленты
RSS_FEEDS=https://news.russlev.com/rss.xml,https://lenta.ru/rss/news

# Поиск картинок (бесплатные источники)
IMAGE_PROVIDER=pexels  # pexels, unsplash, local
